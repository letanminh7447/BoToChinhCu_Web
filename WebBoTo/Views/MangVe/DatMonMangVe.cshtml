@model IEnumerable<WebBoTo.Models.MonAn>
@{
    ViewData["Title"] = "Đặt Mua Mang Về";
    var kh = ViewBag.KhachHang;
}

<style>
    :root {
        --primary-color: #f39c12;
        --bg-card: #1a1a1a;
        --text-light: #e0e0e0;
    }

    .booking-container {
        max-width: 1100px; margin: 40px auto; background: #242424; padding: 30px;
        border-radius: 10px; color: #fff; box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }

    h2 { color: #e6bc53; border-bottom: 2px solid #555; padding-bottom: 15px; text-transform: uppercase; }

    .form-row { display: flex; gap: 20px; margin-bottom: 20px; }
    .form-group label { display: block; margin-bottom: 8px; font-weight: bold; color: #ccc; }
    .form-group input, .form-group select { width: 100%; padding: 10px; border-radius: 5px; border: 1px solid #555; background: #333; color: #fff; }

    .filter-bar { display: flex; gap: 15px; margin: 30px 0 15px 0; background: #1a1a1a; padding: 15px; border-radius: 8px; }
    .filter-bar input, .filter-bar select { padding: 10px; border-radius: 5px; border: 1px solid #444; background: #2a2a2a; color: #fff; width: 100%; outline: none; }

    .menu-table-container { max-height: 500px; overflow-y: auto; border: 1px solid #444; border-radius: 8px; }
    table { width: 100%; border-collapse: collapse; }
    th { background: #3e1f00; color: #e6bc53; padding: 15px; text-align: left; position: sticky; top: 0; z-index: 10; }
    td { padding: 15px; border-bottom: 1px solid #333; }
    tr:hover { background: #2a2a2a; }

    .qty-control { display: flex; align-items: center; gap: 10px; }
    .btn-qty { width: 35px; height: 35px; background: #e6bc53; border: none; font-size: 18px; font-weight: bold; cursor: pointer; border-radius: 5px; }
    .btn-qty:hover { background: #ffcc00; }
    .btn-qty:disabled { background: #555; color: #888; cursor: not-allowed; }
    .qty-input { width: 60px; text-align: center; padding: 8px; border-radius: 5px; border: 1px solid #555; background: #111; color: #fff; font-weight: bold; }

    .btn-confirm { width: 100%; padding: 15px; background: #8B0000; color: #fff; border: none; font-size: 18px; font-weight: bold; cursor: pointer; border-radius: 5px; margin-top: 20px; }
    .btn-confirm:hover { background: #660000; }

    .modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.85); z-index: 2000; align-items: center; justify-content: center; }
    .modal-content { background: #fff; color: #000; width: 650px; max-height: 90vh; overflow-y: auto; padding: 30px; border-radius: 12px; }
    .modal-header { font-size: 24px; font-weight: bold; color: #8B0000; text-align: center; margin-bottom: 20px; border-bottom: 2px solid #eee; padding-bottom: 10px; }
</style>

<div class="booking-container">
    <h2><i class="fas fa-motorcycle"></i> Thông tin giao hàng</h2>
    
    <div class="form-row">
        <div class="form-group">
            <label>Hình thức nhận</label>
            <select id="hinhThuc" class="form-control" onchange="handleHinhThuc()">
                <option value="1">Đến cửa hàng lấy (Miễn phí)</option>
                <option value="2">Giao hàng tận nơi</option>
            </select>
        </div>
        <div id="divDiaChi" class="form-group" style="display: none;">
            <label>Địa chỉ nhận hàng (hoặc dán link Google Maps)</label>
            <div style="display: flex; gap: 5px;">
                <input type="text" id="DiaChiGiaoHang" placeholder="Nhập địa chỉ hoặc dán link Google Maps..." style="flex: 1;" />
                <button type="button" class="btn-check-address" id="btnTinhShip" onclick="calculateDistance()">
                    <i class="fas fa-map-marker-alt"></i> Tính ship
                </button>
            </div>
        </div>
    </div>

    <div id="shipResult" class="ship-info-box" style="display: none; background:#2c3e50; padding:15px; border-radius:8px; margin:15px 0;">
        <span><i class="fas fa-route"></i> Quãng đường: <strong id="lblKm">0</strong> km</span>
        <span><i class="fas fa-money-bill-wave"></i> Phí ship: <strong id="lblPhiShip">0</strong> VNĐ</span>
    </div>

    <h2><i class="fas fa-utensils"></i> Chọn món ăn mang về</h2>

    <div class="filter-bar">
        <input type="text" id="txtSearch" placeholder="🔍 Nhập tên món ăn để tìm..." onkeyup="filterMenu()" />
        <select id="cbCategory" onchange="filterMenu()">
            <option value="ALL">Tất cả danh mục</option>
            @if (ViewBag.DanhMucs != null)
            {
                foreach (var dm in ViewBag.DanhMucs)
                {
                    <option value="@dm.Id_DM">@dm.TenDanhMuc</option>
                }
            }
        </select>
    </div>

    <div class="menu-table-container">
        <table>
            <thead>
                <tr>
                    <th style="width:50%;">Tên món</th>
                    <th style="width:25%;">Giá tiền</th>
                    <th style="width:25%;">Số lượng</th>
                </tr>
            </thead>
            <tbody id="menuBody">
                @foreach (var mon in Model ?? Enumerable.Empty<WebBoTo.Models.MonAn>())
                {
                    <tr class="menu-row" data-name="@mon.TenMon.ToLower()" data-category="@mon.DanhMucId">
                        <td style="font-weight:bold;">@mon.TenMon</td>
                        <td style="color:#ffcc00; font-weight:bold;">@mon.Gia.ToString("N0") VNĐ</td>
                        <td>
                            <div class="qty-control">
                                <button type="button" class="btn-qty btn-minus" disabled onclick="changeQty(this, -1)">-</button>
                                <input type="number" class="qty-input" value="0" min="0" oninput="manualQty(this)"
                                       data-id="@mon.Id_MonAn" data-name="@mon.TenMon" data-price="@mon.Gia" />
                                <button type="button" class="btn-qty btn-plus" onclick="changeQty(this, 1)">+</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <button type="button" class="btn-confirm" onclick="showConfirmation()">
        <i class="fas fa-check-circle"></i> Xác nhận Đặt hàng
    </button>
</div>

<div class="modal-overlay" id="confirmModal">
    <div class="modal-content">
        <div class="modal-header">TỔNG BILL ĐẶT HÀNG MANG VỀ</div>
        
        <ul style="list-style:none; padding:0; margin-bottom:20px;">
            <li><strong>Khách hàng:</strong> @(kh != null ? kh.HoTen : "Khách hàng")</li>
            <li><strong>Hình thức:</strong> <span id="lblHinhThuc"></span></li>
            <li id="liDiaChi" style="display:none;"><strong>Địa chỉ:</strong> <span id="lblDiaChi"></span></li>
        </ul>

        <h5>Danh sách món đã chọn</h5>
        <table style="width:100%; color:#000; border-collapse:collapse; margin-bottom:15px;">
            <thead style="background:#f8f9fa;">
                <tr>
                    <th style="text-align:left; padding:8px;">Món ăn</th>
                    <th style="text-align:center; padding:8px;">Số lượng</th>
                    <th style="text-align:right; padding:8px;">Thành tiền</th>
                </tr>
            </thead>
            <tbody id="lblSelectedItems"></tbody>
        </table>

        <div style="text-align:right; font-size:18px;">
            <div>Tiền món: <span id="lblFoodTotal" style="font-weight:bold;"></span> VNĐ</div>
            <div id="shipLine" style="display:none;">Phí ship: <span id="lblShipTotal" style="font-weight:bold;"></span> VNĐ</div>
            <hr>
            <div style="font-size:22px; color:#8B0000; font-weight:bold;">
                Tổng thanh toán: <span id="lblFinalTotal"></span> VNĐ
            </div>
        </div>

        <div style="margin-top:25px; display:flex; gap:15px;">
            <button class="btn-cancel" onclick="closeModal()" style="flex:1; background:#eee; padding:12px; border:none; border-radius:5px; font-weight:bold;">Sửa lại</button>
            <button class="btn-submit" onclick="submitOrder()" style="flex:2; background:#28a745; color:white; padding:12px; border:none; border-radius:5px; font-weight:bold; cursor:pointer;">
                <i class="fas fa-shopping-cart"></i> ĐẶT ĐƠN NGAY
            </button>
        </div>
    </div>
</div>

<script>
    let totalFood = 0, shipFee = 0, distanceKm = 0;
    const QUAN_LAT = 10.9738343;
    const QUAN_LON = 106.4699543;

    function removeAccents(str) {
        return str.normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/đ/g, 'd').replace(/Đ/g, 'D');
    }

    function handleHinhThuc() {
        const val = document.getElementById('hinhThuc').value;
        document.getElementById('divDiaChi').style.display = (val == "2") ? "block" : "none";
        if (val == "1") {
            shipFee = 0; distanceKm = 0;
            document.getElementById('shipResult').style.display = 'none';
            updateAllTotals();
        }
    }

    async function calculateDistance() {
        const input = document.getElementById('DiaChiGiaoHang').value.trim();
        if (!input) {
            alert("Vui lòng nhập địa chỉ hoặc dán link Google Maps!");
            return;
        }

        const btn = document.getElementById('btnTinhShip');
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang đo đường...';
        btn.disabled = true;

        let latDest = null, lonDest = null;

        try {
            // --- BƯỚC 1: TRÍCH XUẤT TỌA ĐỘ ---
            // Dùng mã ASCII để tránh việc C# (Razor) đọc nhầm ký tự đặc biệt
            const atChar = String.fromCharCode(64); 
            
            // Tìm tọa độ trong link Google Maps (định dạng lat,lon hoặc share link)
            let match = input.match(new RegExp(atChar + "(-?\\d+\\.\\d+),(-?\\d+\\.\\d+)"));
            if (!match) match = input.match(/!3d(-?\d+\.\d+)!4d(-?\d+\.\d+)/);

            if (match) {
                latDest = parseFloat(match[1]);
                lonDest = parseFloat(match[2]);
            } else {
                // Nếu là địa chỉ chữ, dùng Nominatim để đổi ra tọa độ
                const geoRes = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(input + ", Hồ Chí Minh")}&limit=1`);
                const geoData = await geoRes.json();
                if (geoData.length > 0) {
                    latDest = geoData[0].lat;
                    lonDest = geoData[0].lon;
                }
            }

            if (!latDest || !lonDest) throw new Error("Không xác định được vị trí");

            // --- BƯỚC 2: TÌM TUYẾN ĐƯỜNG & LẤY KHOẢNG CÁCH ---
            const osrmUrl = `https://router.project-osrm.org/route/v1/driving/${QUAN_LON},${QUAN_LAT};${lonDest},${latDest}?overview=false`;
            
            const routeRes = await fetch(osrmUrl);
            const routeData = await routeRes.json();

            if (routeData.code !== 'Ok') throw new Error("Không tìm thấy đường đi");

            distanceKm = (routeData.routes[0].distance / 1000).toFixed(1);

            // --- BƯỚC 3: HIỂN THỊ & TÍNH TIỀN ---
            renderShipResult(distanceKm);

        } catch (error) {
            alert("Lỗi: " + error.message);
        } finally {
            btn.innerHTML = '<i class="fas fa-map-marker-alt"></i> Tính ship';
            btn.disabled = false;
        }
    }

    function renderShipResult(km) {
        let ship = 0;
        let numKm = parseFloat(km);

        if (numKm <= 5) ship = numKm * 10000;
        else if (numKm <= 10) ship = 50000 + (numKm - 5) * 8000;
        else ship = 90000 + (numKm - 10) * 5000;

        shipFee = Math.round(ship / 1000) * 1000;

        document.getElementById('lblKm').innerText = km;
        document.getElementById('lblPhiShip').innerText = shipFee.toLocaleString('vi-VN');
        document.getElementById('shipResult').style.display = 'flex';
        
        updateAllTotals(); 
    }

    function changeQty(btn, amount) {
        let input = btn.parentElement.querySelector('.qty-input');
        let newVal = parseInt(input.value) + amount;
        if (newVal < 0) newVal = 0;
        input.value = newVal;
        btn.parentElement.querySelector('.btn-minus').disabled = (newVal === 0);
        calculateFoodTotal();
    }

    function manualQty(input) {
        let val = parseInt(input.value);
        if (isNaN(val) || val < 0) input.value = 0;
        input.parentElement.querySelector('.btn-minus').disabled = (parseInt(input.value) === 0);
        calculateFoodTotal();
    }

    function calculateFoodTotal() {
        totalFood = 0;
        document.querySelectorAll('.qty-input').forEach(i => {
            totalFood += (parseInt(i.value) || 0) * parseFloat(i.getAttribute('data-price'));
        });
        updateAllTotals();
    }

    function updateAllTotals() {
        document.getElementById('sumFood').innerText = totalFood.toLocaleString('vi-VN');
        document.getElementById('sumShip').innerText = shipFee.toLocaleString('vi-VN');
        document.getElementById('sumTotal').innerText = (totalFood + shipFee).toLocaleString('vi-VN');
    }

    function filterMenu() {
        const searchText = removeAccents(document.getElementById("txtSearch").value.toLowerCase().trim());
        const categoryId = document.getElementById("cbCategory").value;
        document.querySelectorAll(".menu-row").forEach(row => {
            const name = removeAccents(row.getAttribute("data-name"));
            const cat = row.getAttribute("data-category");
            row.style.display = (name.includes(searchText) && (categoryId === "ALL" || cat === categoryId)) ? "" : "none";
        });
    }

    function showConfirmation() {
        if (totalFood <= 0) return alert("Chưa chọn món ăn nào!");
        const ht = document.getElementById('hinhThuc').value;
        if (ht == "2" && shipFee <= 0) return alert("Vui lòng tính phí ship trước!");

        document.getElementById('lblHinhThuc').innerText = (ht == "1") ? "Đến quán lấy" : "Giao hàng tận nơi";

        let html = "";
        let foodTotal = 0;
        document.querySelectorAll('.qty-input').forEach(input => {
            let qty = parseInt(input.value);
            if (qty > 0) {
                let name = input.getAttribute('data-name');
                let price = parseFloat(input.getAttribute('data-price'));
                let subtotal = qty * price;
                foodTotal += subtotal;
                html += `<tr><td>${name}</td><td align="center">x${qty}</td><td align="right">${subtotal.toLocaleString('vi-VN')} VNĐ</td></tr>`;
            }
        });

        document.getElementById('lblSelectedItems').innerHTML = html;
        document.getElementById('lblFoodTotal').innerText = foodTotal.toLocaleString('vi-VN');

        if (ht == "2") {
            document.getElementById('shipLine').style.display = 'block';
            document.getElementById('lblShipTotal').innerText = shipFee.toLocaleString('vi-VN');
        } else {
            document.getElementById('shipLine').style.display = 'none';
        }

        document.getElementById('lblFinalTotal').innerText = (foodTotal + shipFee).toLocaleString('vi-VN');
        document.getElementById('confirmModal').style.display = 'flex';
    }

    function closeModal() {
        document.getElementById('confirmModal').style.display = 'none';
    }

    async function submitOrder() {
        let items = [];
        document.querySelectorAll('.qty-input').forEach(input => {
            let qty = parseInt(input.value);
            if (qty > 0) {
                items.push({
                    IdMonAn: parseInt(input.getAttribute('data-id')),
                    SoLuong: qty,
                    DonGia: parseFloat(input.getAttribute('data-price'))
                });
            }
        });

        const ht = parseInt(document.getElementById('hinhThuc').value);
        const dc = ht === 2 ? document.getElementById('DiaChiGiaoHang').value : "Đến cửa hàng lấy";

        const payload = {
            HinhThucNhan: ht,
            DiaChiGiaoHang: dc,
            KhoangCachKm: parseFloat(distanceKm),
            PhiGiaoHang: parseFloat(shipFee),
            TongTienMon: parseFloat(totalFood),
            Items: items
        };

        const btn = document.querySelector('.btn-submit');
        const oldText = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang lưu đơn...';
        btn.disabled = true;

        try {
            const response = await fetch('/MangVe/XacNhanDon', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'same-origin',
                body: JSON.stringify(payload)
            });

            const data = await response.json();

            if (data.success) {
                alert("🎉 " + data.message);
                window.location.href = "/MangVe/LichSuMangVe"; 
            } else {
                alert("❌ Lỗi: " + data.message);
                btn.innerHTML = oldText;
                btn.disabled = false;
            }
        } catch (error) {
            console.error("Lỗi:", error);
            alert("❌ Lỗi kết nối đến máy chủ. Vui lòng thử lại!");
            btn.innerHTML = oldText;
            btn.disabled = false;
        }
    }

    document.addEventListener("DOMContentLoaded", function () {
        var isAuthenticated = @(User.Identity?.IsAuthenticated == true ? "true" : "false");
        if (!isAuthenticated) {
            alert("Bạn chưa đăng nhập. Vui lòng đăng nhập để đặt món mang về.");
            window.location.href = "/Account/Login";
        }
    });
</script>