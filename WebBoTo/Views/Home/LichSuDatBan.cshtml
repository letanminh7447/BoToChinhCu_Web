@model IEnumerable<WebBoTo.Models.DatBan>
@{
    ViewData["Title"] = "Lịch sử đặt bàn";
}

<style>
    .history-container { max-width: 900px; margin: 40px auto; background: #242424; padding: 40px; border-radius: 12px; color: #fff; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
    h2 { text-align: center; color: #e6bc53; text-transform: uppercase; margin-bottom: 30px; }
    
    .booking-card { background: #1a1a1a; border: 1px solid #444; border-radius: 8px; padding: 20px; margin-bottom: 20px; border-left: 5px solid #8B0000; }
    .status-0 { color: #ffcc00; font-weight: bold; } /* Chờ xác nhận */
    .status-1 { color: #28a745; font-weight: bold; } /* Đã xác nhận */
    .status-2 { color: #17a2b8; font-weight: bold; } /* Hoàn thành */
    .status-3 { color: #dc3545; font-weight: bold; } /* Đã hủy */
    
    .booking-header { display: flex; justify-content: space-between; border-bottom: 1px dashed #555; padding-bottom: 10px; margin-bottom: 10px; }
    .booking-details p { margin: 8px 0; color: #ccc; font-size: 15px; }
</style>

<div class="history-container">
    <h2><i class="fas fa-history"></i> Lịch sử Đặt Bàn của bạn</h2>

    @if (!Model.Any())
    {
        <p style="text-align: center; color: #888;">Bạn chưa có lịch sử đặt bàn nào tại quán.</p>
    }
    else
    {
        foreach (var don in Model)
        {
            <div class="booking-card">
                <div class="booking-header">
                    <span style="font-size: 18px; color: #fff;">Mã đơn: <strong>#@don.Id_DatBan</strong></span>
                    <span class="status-@don.TrangThai">
                        <i class="fas fa-info-circle"></i> 
                        @if (don.TrangThai == 0) { <text>⏳ Chờ quán xác nhận</text> }
                        else if (don.TrangThai == 1) { <text>✅ Đã duyệt đặt bàn</text> }
                        else if (don.TrangThai == 2) { <text>🏁 Đã hoàn thành</text> }
                        else { <text>❌ Đã hủy</text> }
                    </span>
                </div>
                <div class="booking-details">
                    <p><i class="fas fa-calendar-day" style="color:#e6bc53;"></i> Thời gian đến: <strong style="color: #fff;">@don.GioDat.ToString(@"hh\:mm") ngày @don.NgayDat.ToString("dd/MM/yyyy")</strong></p>
                    <p><i class="fas fa-users" style="color:#e6bc53;"></i> Số lượng: <strong style="color: #fff;">@don.SoLuongNguoi người</strong></p>
                    <p><i class="fas fa-money-bill-wave" style="color:#e6bc53;"></i> Tiền đã cọc: <strong style="color: #28a745;">@don.TienCoc.ToString("N0") đ</strong></p>
                </div>
            </div>
        }
    }
</div>