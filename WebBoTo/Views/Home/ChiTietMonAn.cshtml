@model WebBoTo.Models.MonAn
@{
    ViewData["Title"] = Model.TenMon;
    // Bỏ qua Layout = null vì chúng ta muốn dùng chung Header/Footer của _Layout.cshtml
}

<style>
    .details-wrapper {
        padding: 50px 20px;
    }
    .details-container {
        max-width: 1000px;
        margin: 0 auto;
        background-color: #242424; /* Nền tối tệp với trang web */
        border-radius: 15px;
        box-shadow: 0 15px 40px rgba(0,0,0,0.8);
        display: flex;
        overflow: hidden;
    }
    
    /* CỘT TRÁI: HÌNH ẢNH TO */
    .details-img-col {
        flex: 1;
        max-width: 50%;
        background-color: #1a1a1a;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .details-img-col img {
        width: 100%;
        height: 100%;
        object-fit: cover; /* Hiển thị ảnh đầy đủ, sắc nét */
    }

    /* CỘT PHẢI: THÔNG TIN MÓN */
    .details-info-col {
        flex: 1;
        padding: 50px 40px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }
    .details-category {
        color: #ff9800;
        font-size: 14px;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 15px;
        font-weight: bold;
    }
    .details-title {
        color: #fff;
        font-size: 32px;
        margin-top: 0;
        margin-bottom: 15px;
        text-transform: uppercase;
    }
    .details-price {
        color: #ffcc00;
        font-size: 32px;
        font-weight: 900;
        margin-bottom: 30px;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.9), 0 0 15px rgba(255, 204, 0, 0.5);
    }
    .details-desc {
        color: #ccc;
        font-size: 16px;
        line-height: 1.8;
        margin-bottom: 40px;
        border-top: 1px dashed #555;
        padding-top: 20px;
    }
    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 12px 25px;
        background-color: #8B0000;
        color: #fff;
        text-decoration: none;
        border-radius: 6px;
        font-weight: bold;
        text-transform: uppercase;
        transition: 0.3s;
        align-self: flex-start;
    }
    .btn-back:hover {
        background-color: #660000;
        color: #ffcc00;
        box-shadow: 0 5px 15px rgba(139, 0, 0, 0.4);
    }
</style>

<div class="details-wrapper">
    <div class="details-container">
        <div class="details-img-col">
            <img src="@(string.IsNullOrEmpty(Model.HinhAnh) ? "https://via.placeholder.com/600x600?text=Mon+An" : "/images/" + Model.HinhAnh)" alt="@Model.TenMon" />
        </div>
        
        <div class="details-info-col">
            <div class="details-category">
                <i class="fas fa-tag"></i> Danh mục: @(Model.DanhMuc?.TenDanhMuc ?? "Món ngon tại quán")
            </div>
            
            <h1 class="details-title">@Model.TenMon</h1>
            
            <div class="details-price">@Model.Gia.ToString("N0") VNĐ</div>
            
            <div class="details-desc">
                @(string.IsNullOrEmpty(Model.MoTa) ? "Hương vị đậm đà, nguyên liệu tươi ngon được chế biến theo công thức độc quyền. Chắc chắn đây sẽ là một trải nghiệm ẩm thực tuyệt vời dành cho bạn!" : Model.MoTa)
            </div>
            
            <a href="/Home/Menu" class="btn-back"><i class="fas fa-arrow-left"></i> Quay lại Menu</a>
        </div>
    </div>
</div>