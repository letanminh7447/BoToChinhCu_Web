@model IEnumerable<WebBoTo.Models.MonAn>
@{
    ViewData["Title"] = "Đặt bàn trước";
    var kh = ViewBag.KhachHang as WebBoTo.Models.TaiKhoan;
}

<style>
    .booking-container { max-width: 1000px; margin: 40px auto; background: #242424; padding: 30px; border-radius: 10px; color: #fff; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
    h2 { color: #e6bc53; border-bottom: 2px solid #555; padding-bottom: 15px; text-transform: uppercase; }
    
    /* Form đặt bàn */
    .form-row { display: flex; gap: 20px; margin-bottom: 20px; }
    .form-group { flex: 1; }
    .form-group label { display: block; margin-bottom: 8px; font-weight: bold; color: #ccc; }
    .form-group input { width: 100%; padding: 10px; border-radius: 5px; border: 1px solid #555; background: #333; color: #fff; box-sizing: border-box; }
    
    /* Bộ lọc Menu */
    .filter-bar { display: flex; gap: 15px; margin: 30px 0 15px 0; background: #1a1a1a; padding: 15px; border-radius: 8px; }
    .filter-bar input, .filter-bar select { padding: 10px; border-radius: 5px; border: 1px solid #444; background: #2a2a2a; color: #fff; width: 100%; outline: none; }
    
    /* Bảng Menu */
    .menu-table-container { max-height: 500px; overflow-y: auto; border: 1px solid #444; border-radius: 8px; }
    table { width: 100%; border-collapse: collapse; }
    th { background: #3e1f00; color: #e6bc53; padding: 15px; text-align: left; position: sticky; top: 0; z-index: 10; }
    td { padding: 15px; border-bottom: 1px solid #333; vertical-align: middle; }
    tr:hover { background: #2a2a2a; }
    
    /* Nút tăng giảm */
    .qty-control { display: flex; align-items: center; gap: 10px; }
    .btn-qty { width: 35px; height: 35px; background: #e6bc53; border: none; font-size: 18px; font-weight: bold; cursor: pointer; border-radius: 5px; transition: 0.2s; }
    .btn-qty:hover { background: #ffcc00; }
    .btn-qty:disabled { background: #555; color: #888; cursor: not-allowed; }
    .qty-input { width: 60px; text-align: center; padding: 8px; border-radius: 5px; border: 1px solid #555; background: #111; color: #fff; font-weight: bold; }

    .btn-confirm { width: 100%; padding: 15px; background: #8B0000; color: #fff; border: none; font-size: 18px; font-weight: bold; cursor: pointer; border-radius: 5px; margin-top: 20px; transition: 0.3s; }
    .btn-confirm:hover { background: #660000; box-shadow: 0 0 15px rgba(139,0,0,0.8); }

    /* Modal Xác Nhận */
    .modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 2000; align-items: center; justify-content: center; }
    .modal-content { background: #fff; color: #000; width: 600px; max-height: 90vh; overflow-y: auto; padding: 30px; border-radius: 10px; }
    .modal-header { border-bottom: 2px solid #8B0000; padding-bottom: 10px; margin-bottom: 20px; color: #8B0000; font-size: 24px; font-weight: bold; text-align: center; }
    .info-list { list-style: none; padding: 0; margin-bottom: 20px; font-size: 15px; }
    .info-list li { margin-bottom: 10px; border-bottom: 1px dashed #ccc; padding-bottom: 5px; }
    .info-list strong { display: inline-block; width: 150px; color: #555; }
    .selected-items { background: #f9f9f9; padding: 15px; border-radius: 5px; border: 1px solid #eee; margin-bottom: 20px; }
    .modal-actions { display: flex; gap: 15px; }
    .btn-submit { flex: 1; padding: 12px; background: #28a745; color: #fff; border: none; border-radius: 5px; font-weight: bold; cursor: pointer; font-size: 16px; }
    .btn-cancel { flex: 1; padding: 12px; background: #dc3545; color: #fff; border: none; border-radius: 5px; font-weight: bold; cursor: pointer; font-size: 16px; }
</style>

<div class="booking-container">
    <h2><i class="fas fa-calendar-alt"></i> Thông tin đặt bàn</h2>
    
    <div class="form-row">
        <div class="form-group">
            <label>Ngày đặt</label>
            <input type="date" id="txtNgay" required />
        </div>
        <div class="form-group">
            <label>Giờ đến</label>
            <input type="time" id="txtGio" required />
        </div>
        <div class="form-group">
            <label>Số lượng người</label>
            <input type="number" id="txtSoNguoi" min="1" value="2" required />
        </div>
    </div>

    <h2><i class="fas fa-utensils"></i> Chọn món ăn trước (Không bắt buộc)</h2>
    
    <div class="filter-bar">
        <input type="text" id="txtSearch" placeholder="🔍 Nhập tên món ăn để tìm..." onkeyup="filterMenu()" />
        <select id="cbCategory" onchange="filterMenu()">
            <option value="ALL">Tất cả danh mục</option>
            @foreach (var dm in ViewBag.DanhMucs)
            {
                <option value="@dm.Id_DM">@dm.TenDanhMuc</option>
            }
        </select>
    </div>

    <div class="menu-table-container">
        <table>
            <thead>
                <tr>
                    <th style="width: 50%;">Tên món</th>
                    <th style="width: 25%;">Giá tiền</th>
                    <th style="width: 25%;">Số lượng</th>
                </tr>
            </thead>
            <tbody id="menuBody">
                @foreach (var mon in Model)
                {
                    <tr class="menu-row" data-name="@mon.TenMon.ToLower()" data-category="@mon.DanhMucId">
                        <td style="font-weight: bold; font-size: 16px;">@mon.TenMon</td>
                        <td style="color: #ffcc00; font-weight: bold;">@mon.Gia.ToString("N0") VNĐ</td>
                        <td>
                            <div class="qty-control">
                                <button type="button" class="btn-qty btn-minus" disabled onclick="changeQty(this, -1)">-</button>
                                <input type="number" class="qty-input" value="0" min="0" oninput="manualQty(this)" 
                                       data-id="@mon.Id_MonAn" data-name="@mon.TenMon" data-price="@mon.Gia" />
                                <button type="button" class="btn-qty btn-plus" onclick="changeQty(this, 1)">+</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <button type="button" class="btn-confirm" onclick="showConfirmation()"><i class="fas fa-check-circle"></i> Xác nhận Đặt bàn</button>
</div>

<div class="modal-overlay" id="confirmModal">
    <div class="modal-content">
        <div class="modal-header">XÁC NHẬN THÔNG TIN ĐẶT BÀN</div>
        
        <ul class="info-list">
            <li><strong>Người đặt:</strong> @kh.HoTen</li>
            <li><strong>Số điện thoại:</strong> @kh.SoDienThoai</li>
            <li><strong>Email:</strong> @kh.Email</li>
            <li><strong>Thời gian:</strong> <span id="lblTime"></span> ngày <span id="lblDate"></span></li>
            <li><strong>Số người:</strong> <span id="lblGuests"></span> người</li>
        </ul>

        <div class="selected-items">
            <h4 style="margin-top:0; color:#8B0000; border-bottom: 1px solid #ccc; padding-bottom:5px;">Danh sách món đã chọn</h4>
            <table style="width: 100%; color: #000; font-size: 14px;">
                <tbody id="lblSelectedItems">
                    </tbody>
            </table>
            <h3 style="text-align: right; color: #8B0000; margin-bottom: 0;">Tổng tiền: <span id="lblTotal">0</span> VNĐ</h3>
        </div>

        <div class="modal-actions">
            <button class="btn-cancel" onclick="closeModal()">Sửa lại</button>
            <button class="btn-submit" onclick="submitBooking()"><i class="fas fa-paper-plane"></i> Gửi yêu cầu Đặt bàn</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // --- HÀM HỖ TRỢ CHUYỂN TIẾNG VIỆT CÓ DẤU THÀNH KHÔNG DẤU ---
        function removeAccents(str) {
            return str.normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/đ/g, 'd').replace(/Đ/g, 'D');
        }

        // --- RÀNG BUỘC NGÀY GIỜ (KHÔNG CHỌN QUÁ KHỨ) ---
        document.addEventListener("DOMContentLoaded", function() {
            var txtNgay = document.getElementById("txtNgay");
            var txtGio = document.getElementById("txtGio");
            
            // Lấy ngày hôm nay theo chuẩn YYYY-MM-DD
            var today = new Date();
            var dd = String(today.getDate()).padStart(2, '0');
            var mm = String(today.getMonth() + 1).padStart(2, '0');
            var yyyy = today.getFullYear();
            var todayString = yyyy + '-' + mm + '-' + dd;
            
            // 1. Khóa lịch: Không cho chọn ngày hôm qua trở về trước
            txtNgay.min = todayString;

            // 2. Lắng nghe khi khách chọn ngày để khóa giờ
            txtNgay.addEventListener('change', function() {
                if(this.value === todayString) {
                    // Nếu khách chọn ngày hôm nay -> Khóa những giờ đã trôi qua
                    var now = new Date();
                    var hh = String(now.getHours()).padStart(2, '0');
                    var min = String(now.getMinutes()).padStart(2, '0');
                    txtGio.min = hh + ":" + min;
                } else {
                    // Nếu chọn ngày ngày mai, ngày mốt -> Mở khóa toàn bộ giờ
                    txtGio.min = ""; 
                }
            });
        });

        // --- 1. TĂNG GIẢM SỐ LƯỢNG MÓN ---
        function changeQty(btn, amount) {
            var input = btn.parentElement.querySelector('.qty-input');
            var newVal = parseInt(input.value) + amount;
            if (newVal < 0) newVal = 0;
            input.value = newVal;
            
            var minusBtn = btn.parentElement.querySelector('.btn-minus');
            minusBtn.disabled = (newVal === 0);
        }

        // --- 2. NHẬP SỐ LƯỢNG TỪ BÀN PHÍM ---
        function manualQty(input) {
            var val = parseInt(input.value);
            if (isNaN(val) || val < 0) { input.value = 0; val = 0; }
            
            var minusBtn = input.parentElement.querySelector('.btn-minus');
            minusBtn.disabled = (val === 0);
        }

        // --- 3. LỌC DANH MỤC VÀ TÌM KIẾM TÊN (HỖ TRỢ TÌM KHÔNG DẤU) ---
        function filterMenu() {
            // Lấy chữ khách gõ, chuyển về chữ thường và XÓA DẤU
            var searchText = removeAccents(document.getElementById("txtSearch").value.toLowerCase());
            var categoryId = document.getElementById("cbCategory").value;
            var rows = document.querySelectorAll(".menu-row");

            rows.forEach(row => {
                var name = row.getAttribute("data-name"); // Tên gốc có dấu
                var nameNoAccent = removeAccents(name);   // Tên gốc đã bị xóa dấu
                var cat = row.getAttribute("data-category");
                
                // Khớp nếu khách gõ có dấu hoặc không dấu đều ra kết quả
                var matchSearch = nameNoAccent.includes(searchText) || name.includes(searchText);
                var matchCategory = (categoryId === "ALL" || cat === categoryId);

                if (matchSearch && matchCategory) {
                    row.style.display = "";
                } else {
                    row.style.display = "none";
                }
            });
        }

        // --- 4. HIỂN THỊ BẢNG XÁC NHẬN TRƯỚC KHI ĐẶT ---
        function showConfirmation() {
            var ngay = document.getElementById("txtNgay").value;
            var gio = document.getElementById("txtGio").value;
            
            if (!ngay || !gio) {
                alert("Vui lòng chọn đầy đủ ngày và giờ đến quán!");
                return;
            }

            // Chốt chặn an toàn: Tránh việc khách cố tình dùng tool lách luật chọn giờ quá khứ
            var selectedDateTime = new Date(ngay + "T" + gio);
            var now = new Date();
            if (selectedDateTime < now) {
                alert("Thời gian đặt bàn không được ở trong quá khứ. Vui lòng chọn lại giờ hợp lệ!");
                return;
            }

            // Gắn thông tin cơ bản
            document.getElementById("lblDate").innerText = ngay;
            document.getElementById("lblTime").innerText = gio;
            document.getElementById("lblGuests").innerText = document.getElementById("txtSoNguoi").value;

            // Quét các món ăn có số lượng > 0
            var inputs = document.querySelectorAll(".qty-input");
            var itemsHtml = "";
            var total = 0;

            inputs.forEach(input => {
                var qty = parseInt(input.value);
                if (qty > 0) {
                    var name = input.getAttribute("data-name");
                    var price = parseFloat(input.getAttribute("data-price"));
                    var subTotal = qty * price;
                    total += subTotal;
                    
                    itemsHtml += `<tr>
                                    <td style='padding: 5px 0;'>${name}</td>
                                    <td style='text-align: center;'>x${qty}</td>
                                    <td style='text-align: right;'>${subTotal.toLocaleString('vi-VN')} đ</td>
                                  </tr>`;
                }
            });

            if (itemsHtml === "") {
                itemsHtml = "<tr><td colspan='3' style='text-align:center; color:#888;'>Khách chỉ đặt bàn, không chọn món trước.</td></tr>";
            }

            document.getElementById("lblSelectedItems").innerHTML = itemsHtml;
            document.getElementById("lblTotal").innerText = total.toLocaleString('vi-VN');

            // Hiện modal
            document.getElementById("confirmModal").style.display = "flex";
        }

        function closeModal() {
            document.getElementById("confirmModal").style.display = "none";
        }

        function submitBooking() {
            // Lấy thông tin ngày giờ
            var ngay = document.getElementById("txtNgay").value;
            var gio = document.getElementById("txtGio").value;
            var soNguoi = document.getElementById("txtSoNguoi").value;

            // Gom các món ăn khách chọn thành 1 mảng
            var items = [];
            var inputs = document.querySelectorAll(".qty-input");
            inputs.forEach(input => {
                var qty = parseInt(input.value);
                if (qty > 0) {
                    items.push({
                        IdMonAn: parseInt(input.getAttribute("data-id")),
                        SoLuong: qty,
                        DonGia: parseFloat(input.getAttribute("data-price"))
                    });
                }
            });

            // Gói thành cục data chuẩn bị gửi
            var payload = {
                NgayDat: ngay,
                GioDat: gio,
                SoNguoi: parseInt(soNguoi),
                Items: items
            };

            // Đổi nút thành Đang xử lý để chống click đúp
            var btn = document.querySelector(".btn-submit");
            var oldText = btn.innerHTML;
            btn.innerHTML = "<i class='fas fa-spinner fa-spin'></i> Đang xử lý...";
            btn.disabled = true;

            // Gửi xuống Controller
            fetch('/Home/SubmitBooking', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            })
            .then(response => response.json())
            .then(res => {
                if (res.success) {
                    alert("🎉 Bạn đã đặt bàn thành công! Hệ thống sẽ chuyển đến trang Lịch sử.");
                    window.location.href = "/Home/LichSuDatBan"; // Chuyển sang trang Cảm ơn
                } else {
                    alert("Có lỗi xảy ra: " + res.message);
                    btn.innerHTML = oldText;
                    btn.disabled = false;
                }
            })
            .catch(err => {
                console.error(err);
                alert("Lỗi kết nối mạng!");
                btn.innerHTML = oldText;
                btn.disabled = false;
            });
        }
    </script>
}