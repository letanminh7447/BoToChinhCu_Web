@{
    ViewData["Title"] = "Liên Hệ";
}

<style>
    /* --- BỘ CSS CHUẨN THEO TONE WEB --- */
    :root { 
        --bg-dark: #121212; 
        --bg-card: #1e1e1e; 
        --gold: #e6bc53; 
        --text-light: #f4f6f9; 
    }
    
    body { background-color: var(--bg-dark); color: var(--text-light); font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
    
    .contact-container { max-width: 1200px; margin: 40px auto; padding: 20px; }
    .section-title { color: var(--gold); text-transform: uppercase; font-size: 28px; margin-bottom: 30px; text-align: center; font-weight: bold; letter-spacing: 1px; }

    /* Lưới chứa Thông tin và Form */
    .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-bottom: 50px; }

    /* 1. KHU VỰC THÔNG TIN (Bên trái) */
    .info-box { background: var(--bg-card); padding: 30px; border-radius: 10px; border-top: 4px solid var(--gold); box-shadow: 0 4px 15px rgba(0,0,0,0.5); }
    .info-box h3 { color: var(--gold); margin-top: 0; margin-bottom: 25px; font-size: 22px; }
    
    .info-item { display: flex; align-items: flex-start; gap: 15px; margin-bottom: 25px; }
    .info-icon { 
        background: var(--gold); color: #000; width: 45px; height: 45px; 
        border-radius: 50%; display: flex; justify-content: center; align-items: center; 
        font-size: 18px; flex-shrink: 0; 
    }
    .info-text h4 { margin: 0 0 5px 0; color: #fff; font-size: 16px; }
    .info-text p { margin: 0; color: #ccc; font-size: 15px; line-height: 1.5; }

    /* 2. KHU VỰC FORM GÓP Ý (Bên phải) */
    .form-box { background: var(--bg-card); padding: 30px; border-radius: 10px; border: 1px solid #333; box-shadow: 0 4px 15px rgba(0,0,0,0.5); }
    .form-box h3 { color: #fff; margin-top: 0; margin-bottom: 20px; font-size: 22px; border-bottom: 1px dashed #444; padding-bottom: 10px; }
    
    .form-group { margin-bottom: 20px; }
    .form-control { 
        width: 100%; padding: 12px 15px; border-radius: 5px; 
        border: 1px solid #444; background: #222; color: #fff; 
        font-size: 15px; box-sizing: border-box; outline: none; transition: 0.3s;
    }
    .form-control:focus { border-color: var(--gold); box-shadow: 0 0 8px rgba(230,188,83,0.3); }
    
    .btn-submit { 
        background: var(--gold); color: #000; font-weight: bold; font-size: 16px; 
        border: none; padding: 12px 25px; border-radius: 5px; cursor: pointer; 
        transition: 0.3s; width: 100%; text-transform: uppercase;
    }
    .btn-submit:hover { background: #cba03a; transform: translateY(-2px); }

    /* 3. KHU VỰC BẢN ĐỒ */
    .map-wrapper { width: 100%; height: 450px; border-radius: 10px; overflow: hidden; border: 2px solid var(--gold); box-shadow: 0 4px 15px rgba(0,0,0,0.5); }
    .map-wrapper iframe { width: 100%; height: 100%; border: none; }

    /* Bố cục cho điện thoại */
    @@media (max-width: 800px) {
        .contact-grid { grid-template-columns: 1fr; }
    }
</style>

<div class="contact-container">
    <h2 class="section-title"><i class="fas fa-headset"></i> LIÊN HỆ VỚI CHÚNG TÔI</h2>

    <div class="contact-grid">
        <div class="info-box">
            <h3>BÒ TƠ CHÍNH CƯ</h3>
            
            <div class="info-item">
                <div class="info-icon"><i class="fas fa-map-marker-alt"></i></div>
                <div class="info-text">
                    <h4>Địa chỉ quán</h4>
                    <p>Số 2, đường Phạm Văn Chèo, Thị Trấn Củ Chi, TP.HCM</p>
                </div>
            </div>

            <div class="info-item">
                <div class="info-icon"><i class="fas fa-phone-alt"></i></div>
                <div class="info-text">
                    <h4>Điện thoại Hotline</h4>
                    <p style="margin: 5px 0;">
                        <a href="tel:0947993499" style="color: var(--gold); font-weight: bold; font-size: 18px; text-decoration: none; transition: 0.3s;" onmouseover="this.style.textShadow='0 0 8px var(--gold)';" onmouseout="this.style.textShadow='none';">
                            0947 993 499
                        </a>
                    </p>
                    <p>Sẵn sàng nhận đặt bàn và tư vấn tiệc</p>
                </div>
            </div>

            <div class="info-item">
                <div class="info-icon"><i class="fas fa-envelope"></i></div>
                <div class="info-text">
                    <h4>Email liên hệ</h4>
                    <p>BoToChinhCu@gmail.com</p>
                </div>
            </div>

            <div class="info-item">
                <div class="info-icon"><i class="fas fa-clock"></i></div>
                <div class="info-text">
                    <h4>Giờ mở cửa</h4>
                    <p>Thứ 2 - Chủ Nhật: <strong>8:00 Sáng - 21:00 Tối</strong></p>
                </div>
            </div>
        </div>

        <div class="form-box">
            <h3>Gửi Góp Ý / Thắc Mắc</h3>
            <p style="color: #aaa; font-size: 14px; margin-bottom: 20px;">Chúng tôi luôn lắng nghe ý kiến của bạn để phục vụ tốt hơn.</p>
            
            @if (TempData["SuccessMessage"] != null)
            {
                <div style="background-color: rgba(40, 167, 69, 0.2); color: #28a745; padding: 12px; border: 1px solid #28a745; border-radius: 5px; margin-bottom: 20px; text-align: center; font-weight: bold;">
                    <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div style="background-color: rgba(220, 53, 69, 0.2); color: #dc3545; padding: 12px; border: 1px solid #dc3545; border-radius: 5px; margin-bottom: 20px; text-align: center; font-weight: bold;">
                    <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
                </div>
            }

            <form action="/Home/SubmitGopY" method="post" onsubmit="this.querySelector('button[type=submit]').disabled=true; this.querySelector('button[type=submit]').innerHTML='<i class=\'fas fa-spinner fa-spin\'></i> Đang gửi...';">
                <div class="form-group">
                    <input type="text" name="hoTen" class="form-control" placeholder="Họ và tên của bạn..." required>
                </div>
                <div class="form-group">
                    <input type="tel" name="soDienThoai" class="form-control" placeholder="Số điện thoại..." required>
                </div>
                <div class="form-group">
                    <input type="email" name="email" class="form-control" placeholder="Email (Không bắt buộc)...">
                </div>
                <div class="form-group">
                    <textarea name="noiDung" class="form-control" rows="4" placeholder="Nhập nội dung tin nhắn hoặc góp ý của bạn..." required></textarea>
                </div>
                <button type="submit" class="btn-submit"><i class="fas fa-paper-plane"></i> Gửi Tin Nhắn</button>
            </form>
        </div>
    </div>

    <h2 class="section-title" style="margin-top: 20px;"><i class="fas fa-map-marked-alt"></i> BẢN ĐỒ ĐƯỜNG ĐI</h2>
    <div class="map-wrapper">
        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3916.855712354571!2d106.49209747451948!3d10.974261655514516!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x310b2b7dee6fc329%3A0x53df78f21cbdccd2!2zQsOyIFTGoSBDaMOtbmggY8aw!5e0!3m2!1svi!2s!4v1774376744211!5m2!1svi!2s" 
                width="100%" 
                height="100%" 
                style="border:0;" 
                allowfullscreen="" 
                loading="lazy" 
                referrerpolicy="no-referrer-when-downgrade">
        </iframe>
    </div>
</div>