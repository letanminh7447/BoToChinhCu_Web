@{
    ViewData["Title"] = "Quên Mật Khẩu";
    Layout = null; // Bỏ Layout chung để thiết kế full màn hình giống trang Login
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Bò Tơ Chính Cư</title>
    <!-- Nhúng FontAwesome để hiển thị các Icon -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <style>
        /* Thiết lập màu nền nâu toàn màn hình giống trang Login */
        body {
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #4A2E2B; /* Màu nền nâu trầm đặc trưng */
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        /* Khung Form màu trắng ở giữa */
        .login-container {
            background-color: #ffffff;
            width: 100%;
            max-width: 420px;
            padding: 40px;
            border-radius: 10px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);
            box-sizing: border-box;
        }

        /* Chữ logo Bò Tơ Chính Cư */
        .brand-name {
            color: #8B0000;
            text-align: center;
            font-family: 'Brush Script MT', cursive, sans-serif;
            font-size: 46px;
            margin: 0 0 5px 0;
            font-weight: normal;
        }

        /* Tiêu đề phụ */
        .page-title {
            text-align: center;
            color: #666;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-size: 14px;
            margin-bottom: 30px;
            font-weight: bold;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            font-size: 13px;
            font-weight: bold;
            margin-bottom: 8px;
            color: #333;
        }

        /* Bọc input để chèn icon */
        .input-wrapper {
            position: relative;
        }

        .input-wrapper i {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: #888;
        }

        .form-control {
            width: 100%;
            padding: 12px 15px 12px 40px; /* Thụt lề trái 40px để chừa chỗ cho Icon */
            border: 1px solid #ddd;
            border-radius: 5px;
            background-color: #f4f8fb; /* Màu nền input hơi xanh nhạt giống ảnh */
            box-sizing: border-box;
            font-size: 14px;
            transition: 0.3s;
            outline: none;
        }

        .form-control:focus {
            border-color: #8B0000;
            background-color: #fff;
            box-shadow: 0 0 5px rgba(139, 0, 0, 0.2);
        }

        /* Nút Submit đỏ */
        .btn-submit {
            width: 100%;
            padding: 14px;
            background-color: #990000;
            color: white;
            border: none;
            border-radius: 5px;
            font-weight: bold;
            font-size: 15px;
            cursor: pointer;
            transition: 0.3s;
            margin-top: 10px;
        }

        .btn-submit:hover {
            background-color: #7a0000;
        }

        .btn-submit:disabled {
            background-color: #aaa;
            cursor: not-allowed;
        }

        /* Link ở dưới cùng */
        .links {
            text-align: center;
            margin-top: 25px;
            font-size: 14px;
        }

        .links a {
            color: #007bff;
            text-decoration: none;
            transition: 0.3s;
        }

        .links a:hover {
            text-decoration: underline;
            color: #0056b3;
        }

        /* Thông báo lỗi */
        .error-message {
            color: #dc3545;
            background-color: #f8d7da;
            border: 1px solid #f5c6cb;
            padding: 12px;
            border-radius: 5px;
            text-align: center;
            font-size: 13px;
            margin-bottom: 20px;
            font-weight: bold;
        }
    </style>
</head>
<body>

    <div class="login-container">
        <h2 class="brand-name">Bò Tơ Chính Cư</h2>
        <p class="page-title">Khôi Phục Mật Khẩu</p>

        @if (ViewBag.Error != null)
        {
            <div class="error-message">
                <i class="fas fa-exclamation-circle"></i> @ViewBag.Error
            </div>
        }

        <form action="/Account/QuenMatKhau" method="post" onsubmit="this.querySelector('.btn-submit').innerHTML='<i class=\'fas fa-spinner fa-spin\'></i> ĐANG GỬI MAIL...'; this.querySelector('.btn-submit').disabled=true;">
            
            <div class="form-group">
                <label>Họ và tên đăng ký</label>
                <div class="input-wrapper">
                    <i class="fas fa-id-card"></i>
                    <input type="text" name="hoTen" class="form-control" required placeholder="Nhập đúng họ tên...">
                </div>
            </div>

            <div class="form-group">
                <label>Email đăng nhập</label>
                <div class="input-wrapper">
                    <i class="fas fa-envelope"></i>
                    <input type="email" name="email" class="form-control" required placeholder="Nhập email...">
                </div>
            </div>

            <button type="submit" class="btn-submit">
                <i class="fas fa-key"></i> LẤY LẠI MẬT KHẨU
            </button>
            
            <div class="links">
                <a href="/Account/Login">Quay lại đăng nhập</a> &nbsp;|&nbsp; 
                <a href="/">Về trang chủ</a>
            </div>
        </form>
    </div>

</body>
</html>