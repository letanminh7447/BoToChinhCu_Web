@model WebBoTo.Models.TaiKhoan
@{
    ViewData["Title"] = "Thông Tin Tài Khoản";
    // Mặc định icon avatar nếu chưa có
    string avatarUrl = string.IsNullOrEmpty(Model.Avatar) 
        ? "https://cdn-icons-png.flaticon.com/512/149/149071.png" 
        : $"/images/avatars/{Model.Avatar}";
}

<style>
    :root { --bg-dark: #121212; --bg-card: #1e1e1e; --gold: #e6bc53; --text-light: #f4f6f9; }
    body { background-color: var(--bg-dark); color: var(--text-light); font-family: sans-serif; }
    .profile-container { max-width: 800px; margin: 50px auto; padding: 30px; background: var(--bg-card); border-radius: 10px; border-top: 4px solid var(--gold); box-shadow: 0 4px 15px rgba(0,0,0,0.5); }
    .section-title { color: var(--gold); text-align: center; text-transform: uppercase; margin-top: 0; margin-bottom: 30px; letter-spacing: 1px; }
    
    .profile-layout { display: flex; gap: 40px; align-items: flex-start; }
    
    /* Cột Avatar */
    .avatar-col { display: flex; flex-direction: column; align-items: center; width: 250px; flex-shrink: 0; }
    .avatar-preview { width: 180px; height: 180px; border-radius: 50%; object-fit: cover; border: 4px solid var(--gold); box-shadow: 0 0 15px rgba(230,188,83,0.3); margin-bottom: 20px; transition: 0.3s; }
    .avatar-preview:hover { transform: scale(1.05); }
    
    .btn-upload { background: #333; color: #fff; padding: 10px 15px; border-radius: 5px; cursor: pointer; border: 1px solid #555; text-align: center; width: 100%; font-size: 14px; transition: 0.3s;}
    .btn-upload:hover { background: #444; border-color: var(--gold); color: var(--gold); }
    #avatarUpload { display: none; }

    /* Cột Form */
    .form-col { flex-grow: 1; }
    .form-group { margin-bottom: 20px; }
    .form-group label { display: block; margin-bottom: 8px; color: #ccc; font-size: 14px; }
    .form-control { width: 100%; padding: 12px 15px; border-radius: 5px; border: 1px solid #444; background: #222; color: #fff; box-sizing: border-box; outline: none; transition: 0.3s;}
    .form-control:focus { border-color: var(--gold); }
    .form-control:disabled { background: #111; color: #777; cursor: not-allowed; }
    
    .btn-submit { background: var(--gold); color: #000; font-weight: bold; border: none; padding: 12px 25px; border-radius: 5px; cursor: pointer; transition: 0.3s; width: 100%; text-transform: uppercase; font-size: 15px;}
    .btn-submit:hover { background: #cba03a; }

    @@media (max-width: 700px) {
        .profile-layout { flex-direction: column; align-items: center; }
        .avatar-col { width: 100%; }
    }
</style>

<div class="profile-container">
    <h2 class="section-title"><i class="fas fa-user-edit"></i> Quản Lý Tài Khoản</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div style="background-color: rgba(40, 167, 69, 0.2); color: #28a745; padding: 15px; border: 1px solid #28a745; border-radius: 5px; margin-bottom: 25px; text-align: center; font-weight: bold;">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
        </div>
    }

    <form action="/Account/CapNhatTaiKhoan" method="post" enctype="multipart/form-data" class="profile-layout" onsubmit="this.querySelector('button[type=submit]').innerHTML='Đang lưu...'; this.querySelector('button[type=submit]').disabled=true;">
        
        <input type="hidden" name="id" value="@Model.Id_TK" />

        <div class="avatar-col">
            <img id="avatar-img-preview" src="@avatarUrl" alt="Avatar" class="avatar-preview" />
            
            <label for="avatarUpload" class="btn-upload">
                <i class="fas fa-camera"></i> Đổi ảnh đại diện
            </label>
            <input type="file" name="avatarFile" id="avatarUpload" accept="image/*" onchange="previewAvatar(event)">
            <p style="font-size: 12px; color: #777; margin-top: 10px; text-align: center;">Chấp nhận file .JPG, .PNG. Tối đa 2MB.</p>
        </div>

        <div class="form-col">
            <div class="form-group">
                <label>Email (Tài khoản đăng nhập)</label>
                <input type="email" class="form-control" value="@Model.Email" disabled>
            </div>

            <div class="form-group">
                <label>Họ và Tên</label>
                <input type="text" name="hoTen" class="form-control" value="@Model.HoTen" required>
            </div>

            <div class="form-group">
                <label>Số điện thoại</label>
                <input type="tel" name="soDienThoai" class="form-control" value="@Model.SoDienThoai" required>
            </div>

            <button type="submit" class="btn-submit"><i class="fas fa-save"></i> Lưu Thay Đổi</button>
        </div>
    </form>
</div>

<script>
    function previewAvatar(event) {
        var reader = new FileReader();
        reader.onload = function(){
            var output = document.getElementById('avatar-img-preview');
            output.src = reader.result;
        };
        if(event.target.files[0]){
            reader.readAsDataURL(event.target.files[0]);
        }
    }
</script>