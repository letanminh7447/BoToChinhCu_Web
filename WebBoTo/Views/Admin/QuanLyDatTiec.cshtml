@{
    Layout = "_Layout";
    ViewData["Title"] = "Quản Lý Đơn Đặt Tiệc";
    var ds = ViewBag.DsTiec;
}

<style>
    /* Bọc ngoài trang */
    .admin-wrapper { max-width: 1300px; margin: 50px auto; min-height: 60vh; padding: 0 20px; font-family: 'Segoe UI', sans-serif; }
    
    /* Thẻ Card tối màu */
    .admin-card {
        background: #1c1c1c;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        padding: 30px 40px;
        border: 1px solid #333;
    }

    /* Tiêu đề */
    .admin-title {
        color: #d4af37;
        text-transform: uppercase;
        border-bottom: 2px solid #8B0000;
        padding-bottom: 15px;
        margin-top: 0;
        margin-bottom: 30px;
        font-weight: 700;
        font-size: 24px;
        letter-spacing: 1px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    /* Bảng dữ liệu */
    .admin-table { width: 100%; border-collapse: separate; border-spacing: 0; }
    .admin-table th {
        background: #8B0000;
        color: #fff;
        padding: 15px;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 13px;
        letter-spacing: 0.5px;
        text-align: left;
    }
    .admin-table th:first-child { border-top-left-radius: 8px; border-bottom-left-radius: 8px; }
    .admin-table th:last-child { border-top-right-radius: 8px; border-bottom-right-radius: 8px; text-align: center; }
    
    .admin-table td {
        padding: 18px 15px;
        border-bottom: 1px dashed #444;
        color: #ddd;
        vertical-align: middle;
        font-size: 15px;
    }
    .admin-table tbody tr { transition: all 0.3s ease; }
    .admin-table tbody tr:hover { background-color: rgba(255, 255, 255, 0.05); }
    .admin-table tbody tr:last-child td { border-bottom: none; }

    /* Text nổi bật */
    .text-gold { color: #d4af37 !important; font-weight: bold; font-size: 16px; }
    .order-id { color: #888; font-family: monospace; font-size: 16px; font-weight: bold; }
    
    /* Nhãn trạng thái (Badge) */
    .status-badge { padding: 6px 12px; border-radius: 30px; font-size: 12px; font-weight: bold; text-transform: uppercase; letter-spacing: 0.5px; display: inline-block; text-align: center; min-width: 110px; }
    .status-pending { background: rgba(255, 193, 7, 0.1); color: #ffc107; border: 1px solid #ffc107; }
    .status-approved { background: rgba(40, 167, 69, 0.1); color: #00ff88; border: 1px solid #00ff88; }
    .status-cancelled { background: rgba(220, 53, 69, 0.1); color: #ff4d4d; border: 1px solid #ff4d4d; }

    /* Nút hành động */
    .btn-action {
        background: transparent;
        border: 1px solid #17a2b8;
        color: #17a2b8;
        padding: 6px 15px;
        border-radius: 5px;
        text-decoration: none;
        font-size: 13px;
        transition: 0.3s;
        display: inline-block;
        white-space: nowrap;
    }
    .btn-action:hover { background: #17a2b8; color: #111; font-weight: bold; box-shadow: 0 0 10px rgba(23, 162, 184, 0.3); }
</style>

<div class="admin-wrapper">
    <div class="admin-card">
        <h2 class="admin-title">
            <span><i class="fas fa-tasks me-2"></i> Quản Lý Đơn Đặt Tiệc Tại Gia</span>
            <span style="font-size: 14px; color: #888; text-transform: none; font-weight: normal;">
                <i class="fas fa-user-shield"></i> Trang dành cho Ban Quản Trị
            </span>
        </h2>

        @if (ds != null && ds.Count > 0)
        {
            <div class="table-responsive">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Mã Đơn</th>
                            <th>Khách Hàng</th>
                            <th>Số Điện Thoại</th>
                            <th>Menu Đã Chọn</th>
                            <th>Số Bàn</th>
                            <th>Ngày Đãi Tiệc</th>
                            <th style="text-align: center;">Trạng Thái</th>
                            <th style="text-align: center;">Hành Động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in ds)
                        {
                            <tr>
                                <td class="order-id">#T@(item.Id_DatTiec)</td>
                                <td><i class="fas fa-user-circle me-1" style="color:#666;"></i> @item.HoTen</td>
                                <td>@item.SoDienThoai</td>
                                <td class="text-gold">@item.TenMenu</td>
                                <td>@item.SoLuongBan <span style="font-size:12px; color:#888;">bàn</span></td>
                                <td><span style="color:#fff;">@item.ThoiGian.ToString("dd/MM/yyyy")</span> <br/> <small style="color:#888;">@item.ThoiGian.ToString("HH:mm")</small></td>
                                <td style="text-align: center;">
                                    @if (item.STrangThai == 0)
                                    {
                                        <span class="status-badge status-pending">Chờ duyệt</span>
                                    }
                                    else if (item.STrangThai == 1)
                                    {
                                        <span class="status-badge status-approved">Đã duyệt</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge status-cancelled">Đã hủy</span>
                                    }
                                </td>
                                <td style="text-align: center;">
                                    <a href="/Admin/ChiTietDatTiec/@item.Id_DatTiec" class="btn-action"><i class="fas fa-eye"></i> Xem Chi Tiết</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div style="color: #888; font-style: italic; text-align: center; padding: 40px 0; font-size: 16px;">
                <i class="fas fa-folder-open" style="font-size: 40px; color: #444; margin-bottom: 15px; display: block;"></i>
                Hiện tại chưa có đơn đặt tiệc nào trên hệ thống.
            </div>
        }
    </div>
</div>