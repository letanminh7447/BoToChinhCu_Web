@model IEnumerable<WebBoTo.Models.MonAn>
@{
    ViewData["Title"] = "Quản lý Menu";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Quản lý Menu - Bò Tơ Chính Cư</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f4f6f9; margin: 0; color: #333; }
        .admin-container { max-width: 1200px; margin: 40px auto; background: #fff; padding: 30px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); }
        
        /* Phần Header */
        .admin-header { display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #eee; padding-bottom: 15px; margin-bottom: 25px; }
        .admin-header h2 { margin: 0; color: #2c3e50; }
        .admin-nav a { text-decoration: none; color: #3498db; margin-left: 20px; font-weight: 600; transition: 0.2s; }
        .admin-nav a:hover { color: #2980b9; }
        .admin-nav .logout-btn { color: #dc3545; }
        .admin-nav .logout-btn:hover { color: #a71d2a; }

        /* Thanh công cụ (Thêm mới + Lọc) */
        .action-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
        
        /* Cụm nút bấm bên trái */
        .button-group { display: flex; gap: 10px; }
        
        .btn-add { background: #28a745; color: #fff; padding: 10px 18px; text-decoration: none; border-radius: 5px; font-weight: bold; transition: 0.3s; display: inline-flex; align-items: center; gap: 8px; }
        .btn-add:hover { background: #218838; box-shadow: 0 2px 5px rgba(0,0,0,0.2); }
        
        .btn-add-category { background: #007bff; color: #fff; padding: 10px 18px; text-decoration: none; border-radius: 5px; font-weight: bold; transition: 0.3s; display: inline-flex; align-items: center; gap: 8px; }
        .btn-add-category:hover { background: #0056b3; box-shadow: 0 2px 5px rgba(0,0,0,0.2); color: #fff;}
        
        .btn-back { background: #6c757d; color: #fff; padding: 10px 18px; text-decoration: none; border-radius: 5px; font-weight: bold; transition: 0.3s; display: inline-flex; align-items: center; gap: 8px; }
        .btn-back:hover { background: #5a6268; box-shadow: 0 2px 5px rgba(0,0,0,0.2); color: #fff;}
        
        /* Form lọc bên phải */
        .filter-form { display: flex; gap: 10px; align-items: center; background: #f8f9fa; padding: 10px 15px; border-radius: 6px; border: 1px solid #ddd; }
        .filter-select { padding: 8px 12px; border: 1px solid #ccc; border-radius: 4px; outline: none; min-width: 200px; font-size: 14px; }

        /* Bảng dữ liệu */
        table { width: 100%; border-collapse: collapse; }
        th, td { padding: 15px; text-align: left; border-bottom: 1px solid #e9ecef; vertical-align: middle; }
        th { background-color: #f8f9fa; font-weight: 600; color: #495057; text-transform: uppercase; font-size: 13px; }
        tr:hover { background-color: #f1f5f9; }
        
        /* Cột hình ảnh */
        .img-preview { width: 90px; height: 60px; object-fit: cover; border-radius: 4px; border: 1px solid #ddd; }

        /* Nút hành động */
        .action-links a { text-decoration: none; padding: 6px 12px; border-radius: 4px; font-size: 13px; font-weight: bold; margin-right: 5px; transition: 0.2s; display: inline-block; }
        .btn-edit { background: #ffc107; color: #212529; }
        .btn-edit:hover { background: #e0a800; }
        .btn-delete { background: #dc3545; color: #fff; }
        .btn-delete:hover { background: #c82333; }
    </style>
</head>
<body>
    <div class="admin-container">
        <div class="admin-header">
            <h2><i class="fas fa-list-alt"></i> Danh sách Menu</h2>
            <div class="admin-nav">
                <a href="/Admin/QuanLyKhachHang"><i class="fas fa-users"></i> Quản lý Khách hàng</a>
                <a href="/Home/Index"><i class="fas fa-home"></i> Về trang chủ</a>
                <a href="/Account/Logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Đăng xuất</a>
            </div>
        </div>

        <div class="action-bar">
            <div class="button-group">
                <a href="/Admin/CreateMenu" class="btn-add"><i class="fas fa-plus"></i> Thêm món mới</a>
                <a href="/Admin/CreateDanhMuc" class="btn-add-category"><i class="fas fa-folder-plus"></i> Thêm Danh Mục</a>
                <a href="/Home/Menu" class="btn-back"><i class="fas fa-arrow-left"></i> Quay Lại Trang Menu</a>
            </div>
            
            <form action="/Admin/QuanLyMenu" method="get" class="filter-form">
                <label for="danhMucId" style="font-weight: 600; font-size: 14px; color: #555;"><i class="fas fa-filter"></i> Lọc danh mục:</label>
                <select name="danhMucId" id="danhMucId" class="filter-select" onchange="this.form.submit()">
                    <option value="">-- Tất cả danh mục --</option>
                    @if (ViewBag.DanhMucs != null)
                    {
                        foreach (var dm in ViewBag.DanhMucs)
                        {
                            if (ViewBag.SelectedDanhMuc != null && ViewBag.SelectedDanhMuc.ToString() == dm.Id_DM.ToString())
                            {
                                <option value="@dm.Id_DM" selected>@dm.TenDanhMuc</option>
                            }
                            else
                            {
                                <option value="@dm.Id_DM">@dm.TenDanhMuc</option>
                            }
                        }
                    }
                </select>
            </form>
        </div>

        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Hình Ảnh</th>
                    <th>Tên Món</th>
                    <th>Danh Mục</th>
                    <th>Giá</th>
                    <th>Mô Tả</th>
                    <th style="text-align: center;">Hành Động</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" style="text-align: center; color: #888; padding: 30px;">Không có món ăn nào trong danh mục này.</td>
                    </tr>
                }
                else
                {
                    foreach (var mon in Model)
                    {
                        <tr>
                            <td style="font-weight: bold; color: #666;">#@mon.Id_MonAn</td>
                            <td>
                                <img src="/images/@mon.HinhAnh" alt="Ảnh" class="img-preview" onerror="this.src='https://via.placeholder.com/90x60?text=No+Image'" />
                            </td>
                            <td style="font-weight: 600; color: #2c3e50;">@mon.TenMon</td>
                            <td><span style="background:#e9ecef; padding:4px 8px; border-radius:4px; font-size:12px;">@mon.DanhMuc?.TenDanhMuc</span></td>
                            <td style="color: #d35400; font-weight: bold;">@mon.Gia.ToString("N0") đ</td>
                            <td style="color: #666; font-size: 14px; max-width: 250px;">@mon.MoTa</td>
                            <td class="action-links" style="text-align: center;">
                                <a href="/Admin/EditMenu/@mon.Id_MonAn" class="btn-edit"><i class="fas fa-pen"></i> Sửa</a>
                                <a href="/Admin/DeleteMenu/@mon.Id_MonAn" class="btn-delete" onclick="return confirm('Bạn có chắc chắn muốn xóa món này không?');"><i class="fas fa-trash"></i> Xóa</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</body>
</html>