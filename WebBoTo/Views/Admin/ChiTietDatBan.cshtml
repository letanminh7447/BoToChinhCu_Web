@model WebBoTo.Models.DatBan
@{
    ViewData["Title"] = "Chi Tiết Đặt Bàn";
    Layout = null;
    var kh = ViewBag.KhachHang as WebBoTo.Models.TaiKhoan;
    var chiTietMon = ViewBag.ChiTietMon as IEnumerable<dynamic>;
    decimal tongTienMon = 0;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Duyệt Đơn Đặt Bàn - Admin</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { font-family: sans-serif; background-color: #f4f6f9; padding: 20px; }
        .container { max-width: 900px; margin: 0 auto; background: #fff; padding: 30px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); display: flex; gap: 30px; }
        .col-left { flex: 6; }
        .col-right { flex: 4; background: #f8f9fa; padding: 20px; border-radius: 8px; border: 1px solid #ddd; }
        h2, h3 { color: #8B0000; margin-top: 0; border-bottom: 2px solid #eee; padding-bottom: 10px; }
        
        .info-group { margin-bottom: 15px; font-size: 15px; }
        .info-group strong { display: inline-block; width: 130px; color: #555; }
        
        table { width: 100%; border-collapse: collapse; margin-top: 15px; font-size: 14px; }
        th, td { padding: 10px; border-bottom: 1px solid #ddd; text-align: left; }
        th { background: #e9ecef; }
        
        /* Form cập nhật */
        .form-group { margin-bottom: 20px; }
        .form-group label { display: block; font-weight: bold; margin-bottom: 8px; color: #333; }
        .form-group select, .form-group input { width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 5px; box-sizing: border-box; font-size: 15px; }
        .form-group input { font-weight: bold; color: #28a745; }
        
        .btn-save { width: 100%; padding: 12px; background: #28a745; color: #fff; border: none; border-radius: 5px; font-size: 16px; font-weight: bold; cursor: pointer; transition: 0.3s; }
        .btn-save:hover { background: #218838; }
        .btn-back { display: block; text-align: center; margin-top: 15px; color: #666; text-decoration: none; }
    </style>
</head>
<body>
    <div class="container">
        <div class="col-left">
            <h2><i class="fas fa-file-invoice"></i> Chi tiết đơn #@Model.Id_DatBan</h2>
            
            <div class="info-group"><strong>Người đặt:</strong> @(kh?.HoTen ?? "N/A")</div>
            <div class="info-group"><strong>Số ĐT:</strong> @(kh?.SoDienThoai ?? "N/A")</div>
            <div class="info-group"><strong>Thời gian đến:</strong> <span style="color: #8B0000; font-weight: bold;">@Model.GioDat.ToString(@"hh\:mm") ngày @Model.NgayDat.ToString("dd/MM/yyyy")</span></div>
            <div class="info-group"><strong>Số lượng khách:</strong> @Model.SoLuongNguoi người</div>
            <div class="info-group"><strong>Ngày tạo đơn:</strong> @Model.NgayTao.ToString("dd/MM/yyyy HH:mm")</div>

            <h3 style="margin-top: 30px;"><i class="fas fa-utensils"></i> Món ăn khách chọn trước</h3>
            @if (chiTietMon == null || !chiTietMon.Any())
            {
                <p style="color: #888; font-style: italic;">Khách chỉ đặt bàn, không chọn món trước.</p>
            }
            else
            {
                <table>
                    <tr>
                        <th>Tên món</th>
                        <th>SL</th>
                        <th>Đơn giá</th>
                        <th>Thành tiền</th>
                    </tr>
                    @foreach (var item in chiTietMon)
                    {
                        decimal thanhTien = item.SoLuong * item.DonGia;
                        tongTienMon += thanhTien;
                        <tr>
                            <td>@item.TenMon</td>
                            <td style="text-align: center; font-weight: bold;">x@(item.SoLuong)</td>
                            <td>@item.DonGia.ToString("N0") đ</td>
                            <td style="text-align: right; font-weight: bold;">@thanhTien.ToString("N0") đ</td>
                        </tr>
                    }
                </table>
                <h4 style="text-align: right; color: #8B0000; margin-top: 15px;">Tổng tiền dự kiến: @tongTienMon.ToString("N0") VNĐ</h4>
            }
        </div>

        <div class="col-right">
            <h3><i class="fas fa-cog"></i> Xử lý Đơn</h3>
            
            <form action="/Admin/CapNhatDatBan" method="post">
                <input type="hidden" name="Id_DatBan" value="@Model.Id_DatBan" />
                
                <div class="form-group">
                    <label>Trạng thái duyệt:</label>
                    <select name="TrangThai">
                        <!option value="0" @(Model.TrangThai == 0 ? "selected" : "")>⏳ Chờ xác nhận</!option>
                        <!option value="1" @(Model.TrangThai == 1 ? "selected" : "")>✅ Đã xác nhận (Duyệt)</!option>
                        <!option value="2" @(Model.TrangThai == 2 ? "selected" : "")>🏁 Khách đã ăn xong</!option>
                        <!option value="3" @(Model.TrangThai == 3 ? "selected" : "")>❌ Hủy đơn</!option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Tiền khách đã cọc (VNĐ):</label>
                    <input type="number" name="TienCoc" value="@Model.TienCoc" min="0" step="1000" placeholder="Ví dụ: 500000" required />
                </div>

                <button type="submit" class="btn-save"><i class="fas fa-save"></i> Lưu thông tin</button>
                <a href="/Admin/QuanLyDatBan" class="btn-back">Quay lại danh sách</a>
            </form>
        </div>
    </div>
</body>
</html>